# ===== Application =====
APP_NAME="CyStar Selective Disclosure"
APP_ENV=development
DEBUG=true

# ===== Security =====
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=replace-me-with-a-32-byte-random-string-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ===== Issuer (Ed25519 keypair) =====
# Leave empty in dev to auto-generate on startup.
# In production, generate once and inject via secrets manager.
ISSUER_NAME="CyStar Demo Issuer"
ISSUER_SIGNING_KEY=
ISSUER_PUBLIC_KEY=

# ===== Database =====
DATABASE_URL=sqlite:///./data/cystar.db

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== Sharing =====
DEFAULT_SHARE_EXPIRY_MINUTES=15
MAX_SHARE_EXPIRY_MINUTES=10080

# ===== Rate limits =====
RATE_LIMIT_VERIFY=30/minute
RATE_LIMIT_AUTH=10/minute

# ===== Public URLs =====
PUBLIC_FRONTEND_URL=http://localhost:3000
